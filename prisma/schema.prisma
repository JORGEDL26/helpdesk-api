generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       Int      @id @default(autoincrement())
  name     String
  email    String   @unique
  password String
  role     String   @default("user")
  tickets  Ticket[]
}

model Ticket {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  status      String   @default("aberto")
  createdAt   DateTime @default(now())
  userId      Int
  user        User     @relation(fields: [userId], references: [id])
}